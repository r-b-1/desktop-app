{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Permissions for Desktop Chat: screenshots, file dialogs, and filesystem access",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "screenshots:default",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "dialog:allow-message",
    "dialog:allow-ask"
  ]
}
